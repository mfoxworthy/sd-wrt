config globals 'globals'
	option probe_interval    '5'
	option degrade_latency   '500'
	option degrade_loss      '10'
	option degrade_count     '3'
	option recover_interval  '30'
	option recover_latency   '200'
	option recover_loss      '2'

config link 'satellite'
	option ifname          'eth1'
	option role            'default'
	option probe_target    '1.1.1.1'
	option table           '102'
	option fwmark          '0x02'

config link 'cellular'
	option ifname          'wwan0'
	option role            'interactive'
	option probe_target    '8.8.8.8'
	option table           '101'
	option fwmark          '0x01'

config rule 'dns'
	option proto  'udp tcp'
	option dport  '53'
	option role   'interactive'

config rule 'management'
	option proto   'tcp'
	option dport   '22 80 443'
	option dest_ip '54.218.103.98'
	option role    'interactive'
